   },
   "cell_type": "code",
   "source": [
    "from sklearn.ensemble import RandomForestClassifier\n",
    "\n",
    "# Try different configurations to reduce overfitting\n",
    "rf_tuned = RandomForestClassifier(\n",
    "    n_estimators=100,\n",
    "    max_depth=10,           # Limit tree depth\n",
    "    min_samples_split=20,   # Minimum samples to split a node\n",
    "    min_samples_leaf=10,    # Minimum samples in leaf node\n",
    "    max_features='sqrt',    # Use sqrt(n_features) at each split\n",
    "    random_state=42,\n",
    "    n_jobs=-1\n",
    ")\n",
    "\n",
    "rf_tuned.fit(X_train_scaled, y_train)\n",
    "\n",
    "# Predictions\n",
    "y_train_pred_tuned = rf_tuned.predict(X_train_scaled)\n",
    "y_test_pred_tuned = rf_tuned.predict(X_test_scaled)\n",
    "y_test_proba_tuned = rf_tuned.predict_proba(X_test_scaled)[:, 1]\n",
    "\n",
    "# Metrics\n",
    "train_acc_tuned = accuracy_score(y_train, y_train_pred_tuned)\n",
    "test_acc_tuned = accuracy_score(y_test, y_test_pred_tuned)\n",
    "test_auc_tuned = roc_auc_score(y_test, y_test_proba_tuned)\n",
    "\n",
    "print(\"=== Tuned Random Forest Performance ===\")\n",
    "print(f\"Train Accuracy: {train_acc_tuned:.4f}\")\n",
    "print(f\"Test Accuracy:  {test_acc_tuned:.4f}\")\n",
    "print(f\"AUC-ROC:        {test_auc_tuned:.4f}\")\n",
    "print(f\"📊 Accuracy Gap: {train_acc_tuned - test_acc_tuned:.4f}\")\n",
    "\n",
    "if train_acc_tuned - test_acc_tuned < 0.1:\n",
    "    print(\"✅ Overfitting significantly reduced!\")\n",
    "else:\n",
    "    print(\"⚠️ Still some overfitting, consider more regularization\")\n",
    "\n",
    "# Compare all models\n",
    "print(\"\\n=== Final Model Comparison ===\")\n",
    "print(f\"Logistic Regression:   {test_acc:.4f} accuracy, {test_auc:.4f} AUC\")\n",
    "print(f\"Random Forest (default): {test_acc_rf:.4f} accuracy, {test_auc_rf:.4f} AUC\")\n",
    "print(f\"Random Forest (tuned):   {test_acc_tuned:.4f} accuracy, {test_auc_tuned:.4f} AUC\")\n",
    "\n",
    "if test_acc_tuned > test_acc_rf:\n",
    "    print(\"✅ Tuned model improved!\")\n",
    "else:\n",
    "    print(\"⚠️ Default model still better - let's try different parameters\")"
   ],
