  {
   "metadata": {},
   "cell_type": "markdown",
   "source": "### Final Feature Importance Comparison",
   "id": "5588614e7cbd29a1"
  },
  {
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-06-25T06:06:38.787114Z",
     "start_time": "2026-06-25T06:06:38.548987Z"
    }
   },
   "cell_type": "code",
   "source": [
    "# Compare feature importance from both models\n",
    "feature_importance_rf = pd.DataFrame({\n",
    "    'feature': X.columns,\n",
    "    'importance': rf_model.feature_importances_\n",
    "}).sort_values('importance', ascending=False)\n",
    "\n",
    "# Get top features from both models\n",
    "top_features = feature_importance_rf.head(10)\n",
    "\n",
    "print(\"=== Top 10 Features (Random Forest) ===\")\n",
    "print(top_features.to_string(index=False))\n",
    "\n",
    "# Visualize comparison\n",
    "fig, axes = plt.subplots(1, 2, figsize=(16, 6))\n",
    "\n",
    "# Plot 1: Random Forest Feature Importance\n",
