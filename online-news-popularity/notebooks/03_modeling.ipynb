    "from sklearn.preprocessing import PolynomialFeatures\n",
    "\n",
    "# Add interaction terms for top features\n",
    "top_features = ['LDA_04', 'LDA_00', 'LDA_03', 'is_weekend',\n",
    "                'data_channel_is_socmed', 'keyword_score']\n",
    "\n",
    "poly = PolynomialFeatures(degree=2, include_bias=False, interaction_only=True)\n",
    "X_poly = poly.fit_transform(X_train_scaled[:, :len(top_features)])\n",
    "\n",
    "# Train XGBoost with these new features\n",
    "xgb_poly = XGBClassifier(\n",
    "    n_estimators=150,\n",
    "    max_depth=6,\n",
    "    learning_rate=0.1,\n",
    "    random_state=42,\n",
    "    use_label_encoder=False,\n",
    "    eval_metric='logloss'\n",
    ")\n",
    "xgb_poly.fit(X_poly, y_train)"
   ],
