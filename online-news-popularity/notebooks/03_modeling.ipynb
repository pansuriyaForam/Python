    }
   },
   "cell_type": "code",
   "source": [
    "# Get feature coefficients\n",
    "feature_importance = pd.DataFrame({\n",
    "    'feature': X.columns,\n",
    "    'coefficient': log_reg.coef_[0]\n",
    "}).sort_values('coefficient', ascending=False)\n",
    "\n",
    "print(\"=== Top 15 Most Important Features ===\")\n",
    "print(feature_importance.head(15).to_string(index=False))\n",
    "\n",
    "print(\"\\n=== Top 15 Least Important Features ===\")\n",
    "print(feature_importance.tail(15).to_string(index=False))\n",
    "\n",
    "# Visualize\n",
    "plt.figure(figsize=(12, 8))\n",
    "top_features = pd.concat([\n",
    "    feature_importance.head(8),\n",
    "    feature_importance.tail(8)\n",
    "])\n",
    "top_features = top_features.sort_values('coefficient')\n",
    "\n",
    "plt.barh(top_features['feature'], top_features['coefficient'],\n",
    "         color=['red' if x < 0 else 'green' for x in top_features['coefficient']])\n",
    "plt.xlabel('Coefficient Value (Log-Odds)')\n",
    "plt.title('Top 15 Logistic Regression Coefficients')\n",
    "plt.axvline(x=0, color='black', linestyle='-', alpha=0.3)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ],
