    }
   },
   "cell_type": "code",
   "source": [
    "# Test different configurations\n",
    "configs = [\n",
    "    {'max_depth': 5, 'min_samples_split': 20, 'min_samples_leaf': 10},\n",
    "    {'max_depth': 7, 'min_samples_split': 20, 'min_samples_leaf': 10},\n",
    "    {'max_depth': 10, 'min_samples_split': 20, 'min_samples_leaf': 10},\n",
    "    {'max_depth': 10, 'min_samples_split': 30, 'min_samples_leaf': 15},\n",
    "    {'max_depth': 12, 'min_samples_split': 25, 'min_samples_leaf': 12},\n",
    "]\n",
    "\n",
    "results = []\n",
    "for params in configs:\n",
    "    rf = RandomForestClassifier(\n",
    "        n_estimators=100,\n",
    "        **params,\n",
    "        random_state=42,\n",
    "        n_jobs=-1\n",
    "    )\n",
    "    rf.fit(X_train_scaled, y_train)\n",
    "\n",
    "    train_acc = accuracy_score(y_train, rf.predict(X_train_scaled))\n",
    "    test_acc = accuracy_score(y_test, rf.predict(X_test_scaled))\n",
    "\n",
    "    results.append({\n",
    "        **params,\n",
    "        'train_acc': train_acc,\n",
    "        'test_acc': test_acc,\n",
    "        'gap': train_acc - test_acc\n",
    "    })\n",
    "\n",
    "# Display results\n",
    "results_df = pd.DataFrame(results)\n",
    "print(\"=== Parameter Search Results ===\")\n",
    "print(results_df.to_string(index=False))\n",
    "\n",
    "# Find best configuration\n",
    "best_idx = results_df['test_acc'].idxmax()\n",
    "print(f\"\\n🏆 Best Configuration:\")\n",
    "print(f\"  max_depth: {results_df.loc[best_idx, 'max_depth']}\")\n",
    "print(f\"  min_samples_split: {results_df.loc[best_idx, 'min_samples_split']}\")\n",
    "print(f\"  min_samples_leaf: {results_df.loc[best_idx, 'min_samples_leaf']}\")\n",
    "print(f\"  Test Accuracy: {results_df.loc[best_idx, 'test_acc']:.4f}\")\n",
    "print(f\"  Train-Test Gap: {results_df.loc[best_idx, 'gap']:.4f}\")"
   ],
