    }
   },
   "cell_type": "code",
   "source": [
    "from sklearn.ensemble import VotingClassifier\n",
    "\n",
    "# Create ensemble of our best models\n",
    "ensemble = VotingClassifier(\n",
    "    estimators=[\n",
    "        ('logistic', log_reg),\n",
    "        ('rf', RandomForestClassifier(\n",
    "            n_estimators=100,\n",
    "            max_depth=10,\n",
    "            min_samples_split=30,\n",
    "            min_samples_leaf=15,\n",
    "            random_state=42,\n",
    "            n_jobs=-1\n",
    "        )),\n",
    "        ('xgb', XGBClassifier(\n",
    "            n_estimators=100,\n",
    "            max_depth=6,\n",
    "            learning_rate=0.1,\n",
    "            subsample=0.8,\n",
    "            colsample_bytree=0.8,\n",
    "            random_state=42,\n",
    "            use_label_encoder=False,\n",
    "            eval_metric='logloss'\n",
    "        ))\n",
    "    ],\n",
    "    voting='soft'  # Use predicted probabilities\n",
    ")\n",
    "\n",
    "ensemble.fit(X_train_scaled, y_train)\n",
    "\n",
    "# Predictions\n",
    "y_train_pred_ens = ensemble.predict(X_train_scaled)\n",
    "y_test_pred_ens = ensemble.predict(X_test_scaled)\n",
    "y_test_proba_ens = ensemble.predict_proba(X_test_scaled)[:, 1]\n",
    "\n",
    "train_acc_ens = accuracy_score(y_train, y_train_pred_ens)\n",
    "test_acc_ens = accuracy_score(y_test, y_test_pred_ens)\n",
    "test_auc_ens = roc_auc_score(y_test, y_test_proba_ens)\n",
    "\n",
    "print(\"=== Ensemble Model Performance ===\")\n",
    "print(f\"Train Accuracy: {train_acc_ens:.4f}\")\n",
    "print(f\"Test Accuracy:  {test_acc_ens:.4f}\")\n",
    "print(f\"AUC-ROC:        {test_auc_ens:.4f}\")\n",
    "print(f\"📊 Accuracy Gap: {train_acc_ens - test_acc_ens:.4f}\")"
   ],
