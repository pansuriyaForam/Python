  {
   "metadata": {},
   "cell_type": "markdown",
   "source": "### Cross-Validation",
   "id": "f026efbfd23641ce"
  },
  {
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-06-25T06:06:37.309437Z",
     "start_time": "2026-06-25T06:06:36.875551Z"
    }
   },
   "cell_type": "code",
   "source": [
    "# Cross-validation scores\n",
    "cv_scores = cross_val_score(log_reg, X_train_scaled, y_train, cv=5, scoring='accuracy')\n",
    "cv_auc = cross_val_score(log_reg, X_train_scaled, y_train, cv=5, scoring='roc_auc')\n",
    "\n",
    "print(\"=== 5-Fold Cross-Validation ===\")\n",
    "print(f\"Accuracy: {cv_scores.mean():.4f} (±{cv_scores.std():.4f})\")\n",
    "print(f\"AUC-ROC:  {cv_auc.mean():.4f} (±{cv_auc.std():.4f})\")"
   ],
   "id": "81f0db1e8e10f431",
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "=== 5-Fold Cross-Validation ===\n",
      "Accuracy: 0.6346 (±0.0059)\n",
      "AUC-ROC:  0.6815 (±0.0069)\n"
     ]
    }
   ],
   "execution_count": 7
  },
  {
   "metadata": {},
   "cell_type": "markdown",
   "source": "### Random Forest Classifier",
   "id": "9d7bb826b0b9854"
  },
  {
   "metadata": {
    "ExecuteTime": {
     "end_time": "2026-06-25T06:06:38.536881Z",
     "start_time": "2026-06-25T06:06:37.317444Z"
    }
   },
   "cell_type": "code",
   "source": [
    "# Train Random Forest\n",
    "from sklearn.ensemble import RandomForestClassifier\n",
    "\n",
    "rf_model = RandomForestClassifier(n_estimators=100, random_state=42, n_jobs=-1)\n",
    "rf_model.fit(X_train_scaled, y_train)\n",
    "\n",
    "# Predictions\n",
    "y_train_pred_rf = rf_model.predict(X_train_scaled)\n",
    "y_test_pred_rf = rf_model.predict(X_test_scaled)\n",
    "y_test_proba_rf = rf_model.predict_proba(X_test_scaled)[:, 1]\n",
    "\n",
    "# Metrics\n",
    "train_acc_rf = accuracy_score(y_train, y_train_pred_rf)\n",
    "test_acc_rf = accuracy_score(y_test, y_test_pred_rf)\n",
    "test_precision_rf = precision_score(y_test, y_test_pred_rf)\n",
    "test_recall_rf = recall_score(y_test, y_test_pred_rf)\n",
    "test_f1_rf = f1_score(y_test, y_test_pred_rf)\n",
    "test_auc_rf = roc_auc_score(y_test, y_test_proba_rf)\n",
    "\n",
    "print(\"=== Random Forest Performance ===\")\n",
    "print(f\"Train Accuracy: {train_acc_rf:.4f}\")\n",
    "print(f\"Test Accuracy:  {test_acc_rf:.4f}\")\n",
    "print(f\"Precision:      {test_precision_rf:.4f}\")\n",
    "print(f\"Recall:         {test_recall_rf:.4f}\")\n",
    "print(f\"F1-Score:       {test_f1_rf:.4f}\")\n",
    "print(f\"AUC-ROC:        {test_auc_rf:.4f}\")\n",
    "\n",
    "# Check for overfitting\n",
    "print(f\"\\n📊 Accuracy Gap (Train - Test): {train_acc_rf - test_acc_rf:.4f}\")\n",
    "if train_acc_rf - test_acc_rf > 0.05:\n",
    "    print(\"⚠️ Significant overfitting - consider using fewer trees or max_depth\")\n",
    "else:\n",
    "    print(\"✅ No significant overfitting detected\")\n",
    "\n",
    "# Compare with Logistic Regression\n",
    "print(\"\\n=== Model Comparison ===\")\n",
    "print(f\"Logistic Regression:  {test_acc:.4f} accuracy, {test_auc:.4f} AUC\")\n",
    "print(f\"Random Forest:        {test_acc_rf:.4f} accuracy, {test_auc_rf:.4f} AUC\")\n",
    "print(f\"📈 Improvement:       {(test_acc_rf - test_acc)*100:.2f}% accuracy, {(test_auc_rf - test_auc)*100:.2f}% AUC\")"
   ],
