    "# Let's test one promising feature: media count\n",
    "df['media_count'] = df['num_imgs'] + df['num_videos']\n",
    "\n",
    "# Check correlation with log-shares\n",
    "media_corr = df['media_count'].corr(log_shares)\n",
    "img_corr = df['num_imgs'].corr(log_shares)\n",
    "video_corr = df['num_videos'].corr(log_shares)\n",
    "\n",
    "print(\"=== Media Feature Analysis ===\")\n",
    "print(f\"Media Count Correlation: {media_corr:.4f}\")\n",
    "print(f\"Images Correlation: {img_corr:.4f}\")\n",
    "print(f\"Videos Correlation: {video_corr:.4f}\")\n",
    "\n",
    "# Check distribution of media count\n",
    "plt.figure(figsize=(10, 4))\n",
    "plt.subplot(1, 2, 1)\n",
    "df['media_count'].hist(bins=50, edgecolor='black', alpha=0.7)\n",
    "plt.title('Distribution of Media Count')\n",
    "plt.xlabel('Number of Media Elements')\n",
    "\n",
    "plt.subplot(1, 2, 2)\n",
    "# Box plot by shares quartile\n",
