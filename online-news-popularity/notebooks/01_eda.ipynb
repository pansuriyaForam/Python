   },
   "cell_type": "code",
   "source": [
    "# Calculate correlations with log-transformed shares\n",
    "log_shares = np.log1p(df['shares'])\n",
    "\n",
    "# Correlation with all features (excluding non-predictive)\n",
    "feature_cols = [col for col in df.columns if col not in ['url', 'timedelta', 'shares']]\n",
    "correlations = []\n",
    "\n",
    "for col in feature_cols:\n",
    "    corr = df[col].corr(log_shares)\n",
    "    correlations.append((col, corr))\n",
    "\n",
    "# Sort by absolute correlation\n",
    "correlations.sort(key=lambda x: abs(x[1]), reverse=True)\n",
    "\n",
    "print(\"=== Top 15 Features Most Correlated with Log-Shares ===\\n\")\n",
    "print(\"Feature | Correlation\")\n",
    "print(\"-\" * 50)\n",
    "for feature, corr in correlations[:15]:\n",
    "    print(f\"{feature:<40} {corr:.4f}\")\n",
    "\n",
    "# Visualize top correlations\n",
    "top_features = [f[0] for f in correlations[:15]]\n",
    "top_corrs = [f[1] for f in correlations[:15]]\n",
    "\n",
    "plt.figure(figsize=(12, 8))\n",
    "plt.barh(top_features, top_corrs)\n",
    "plt.xlabel('Correlation with Log-Shares')\n",
    "plt.title('Top 15 Features Correlated with Article Popularity')\n",
    "plt.gca().invert_yaxis()\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ],
